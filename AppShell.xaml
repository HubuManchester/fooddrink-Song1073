<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FoodDrinkApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FoodDrinkApp"
    xmlns:views="clr-namespace:FoodDrinkApp.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E2E}"
    Shell.TabBarTitleColor="{AppThemeBinding Light=#512BD4, Dark=#ac99ea}"
    Shell.TabBarUnselectedColor="{AppThemeBinding Light=#757575, Dark=#9E9E9E}">

    <TabBar>
        <Tab Title="Home" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
        <Tab Title="Hardware" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:HardwarePage}" />
        </Tab>
        <Tab Title="Settings" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>