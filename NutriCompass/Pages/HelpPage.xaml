<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="NutriCompass.Pages.HelpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NutriCompass.ViewModels"
    Title="Help"
    x:DataType="viewModels:HelpPageViewModel"
    SemanticProperties.Description="Support overview page">

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="20">

            <Label
                Text="Support Resources"
                FontSize="32"
                FontAttributes="Bold"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Learn how WCAG standards are implemented, how to wire hardware integrations, and how to test accessibility features."
                FontSize="16"
                SemanticProperties.Description="Support description"
                LineBreakMode="WordWrap" />

            <Entry
                Placeholder="Search support topics"
                FontSize="14"
                Margin="0,10"
                ClearButtonVisibility="WhileEditing" />

            <Border
                Padding="16"
                Stroke="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle"
                StrokeThickness="1"
                Background="{AppThemeBinding Light={StaticResource SurfaceBackground}, Dark={StaticResource SurfaceBackgroundDark}}">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Accessibility Checklist"
                        FontAttributes="Bold"
                        SemanticProperties.Description="Accessibility checklist heading" />
                    <Label
                        Text="AutomationProperties.Name is enforced. Contrast ratios exceed 4.5:1. Focus order mirrors visual layout."
                        FontSize="14"
                        SemanticProperties.Description="Checklist detail"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Border
                Padding="16"
                Stroke="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle"
                StrokeThickness="1"
                Background="{AppThemeBinding Light={StaticResource SurfaceBackground}, Dark={StaticResource OffBlack}}">
                <VerticalStackLayout Spacing="10">
                    <Label
                        Text="Hardware Interface"
                        FontAttributes="Bold"
                        SemanticProperties.Description="Hardware heading" />
                    <Label
                        Text="Describe sensors, weights, or peripherals in English only to keep accessibility support consistent for screen readers."
                        FontSize="14"
                        SemanticProperties.Description="Hardware description"
                        LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Return to Home"
                Command="{Binding GoHomeCommand}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
