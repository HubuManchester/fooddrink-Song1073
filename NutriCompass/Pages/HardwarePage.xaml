<?xml version="1.0" encoding="utf-8" ?>
<pages:AccessibleContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:NutriCompass.Pages"
    x:Class="NutriCompass.Pages.HardwarePage"
    Title="Hardware"
    AutomationProperties.Name="Hardware Page">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="18">
            <Label
                Text="Hardware Demos"
                Style="{StaticResource Headline}"
                AutomationProperties.Name="Hardware header" />

            <Label
                Text="This page will expose location, geocoding, and haptic feedback demos."
                AutomationProperties.Name="Hardware explanation" />

            <Frame
                CornerRadius="16"
                Padding="16"
                BorderColor="{StaticResource Gray300Brush}"
                BackgroundColor="{StaticResource CreamBrush}">
                <VerticalStackLayout Spacing="10">
                    <Button
                        x:Name="RefreshLocationButton"
                        Text="Refresh location"
                        AutomationProperties.Name="Refresh location button"
                        Clicked="OnRefreshLocationClicked" />

                    <Label
                        Text="Location status"
                        AutomationProperties.Name="Location status label"
                        FontAttributes="Bold" />

                    <Label
                        x:Name="LocationStatusLabel"
                        Text="Tap refresh to request the current location."
                        AutomationProperties.Name="Location status value" />

                    <Label
                        Text="Coordinates"
                        FontAttributes="Bold"
                        AutomationProperties.Name="Coordinates label" />
                    <Label
                        x:Name="CoordinatesValueLabel"
                        Text="N/A"
                        AutomationProperties.Name="Coordinates value" />

                    <Label
                        Text="Placemark"
                        FontAttributes="Bold"
                        AutomationProperties.Name="Placemark label" />
                    <Label
                        x:Name="PlacemarkValueLabel"
                        Text="N/A"
                        AutomationProperties.Name="Placemark value" />
                </VerticalStackLayout>
            </Frame>

            <Frame
                CornerRadius="16"
                Padding="16"
                BorderColor="{StaticResource Gray300Brush}"
                BackgroundColor="{StaticResource CreamBrush}">
                <VerticalStackLayout Spacing="10">
                    <Button
                        x:Name="HapticButton"
                        Text="Trigger Haptic Simulation"
                        AutomationProperties.Name="Test haptic button"
                        Clicked="OnHapticButtonClicked" />
                    <Label
                        x:Name="HapticCountLabel"
                        Text="Haptic taps: 0"
                        AutomationProperties.Name="Haptic count label" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</pages:AccessibleContentPage>
