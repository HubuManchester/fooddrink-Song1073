<?xml version="1.0" encoding="utf-8" ?>
<pages:AccessibleContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:NutriCompass.Pages"
    x:Class="NutriCompass.Pages.HardwarePage"
    Title="Hardware"
    AutomationProperties.Name="Hardware Page">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="18">
            <Label
                Text="Hardware Demos"
                Style="{StaticResource Headline}"
                AutomationProperties.Name="Hardware header" />

            <Label
                Text="This page will expose location, geocoding, and haptic feedback demos."
                AutomationProperties.Name="Hardware explanation" />

            <Button
                Text="Trigger Haptic Simulation"
                AutomationProperties.Name="Test haptic button" />
        </VerticalStackLayout>
    </ScrollView>

</pages:AccessibleContentPage>
