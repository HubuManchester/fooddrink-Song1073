<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:NutriCompass.ViewModels"
    x:Class="NutriCompass.Pages.ProfilePage"
    x:DataType="viewModels:ProfileViewModel"
    Title="Personal Profile"
    AutomationProperties.Name="Profile calculator">

    <ScrollView>
        <VerticalStackLayout
            Padding="24"
            Spacing="18"
            AutomationProperties.HelpText="Enter your height, weight, age, and gender to calculate BMI and recommended calories.">

            <Label
                Text="Personal Health Profile"
                FontSize="28"
                FontAttributes="Bold"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Provide your most recent height, weight, and age. All prompts respect WCAG naming for assistive tech."
                FontSize="16"
                LineBreakMode="WordWrap" />

            <Border
                Padding="16"
                Stroke="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle"
                StrokeThickness="1"
                Background="{AppThemeBinding Light={StaticResource SurfaceBackground}, Dark={StaticResource OffBlack}}">
                <VerticalStackLayout Spacing="12">
                    <Entry
                        Text="{Binding WeightText}"
                        Placeholder="Weight in kilograms"
                        Keyboard="Numeric"
                        AutomationProperties.Name="Weight input"
                        AutomationProperties.HelpText="Enter weight as a positive number"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />

                    <Entry
                        Text="{Binding HeightText}"
                        Placeholder="Height in centimeters"
                        Keyboard="Numeric"
                        AutomationProperties.Name="Height input"
                        AutomationProperties.HelpText="Enter height as a positive number"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />

                    <Entry
                        Text="{Binding AgeText}"
                        Placeholder="Age in years"
                        Keyboard="Numeric"
                        AutomationProperties.Name="Age input"
                        AutomationProperties.HelpText="Enter age as a whole number"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />

                    <Picker
                        Title="Gender"
                        ItemsSource="{Binding GenderOptions}"
                        SelectedItem="{Binding SelectedGender}"
                        AutomationProperties.Name="Gender selector"
                        AutomationProperties.HelpText="Choose your gender for the calorie formula." />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Calculate BMI &amp; Calories"
                Command="{Binding CalculateCommand}"
                FontSize="16"
                CornerRadius="12"
                AutomationProperties.Name="Calculate button" />

            <Label
                Text="{Binding ValidationMessage}"
                TextColor="Red"
                FontAttributes="Bold"
                LineBreakMode="WordWrap"
                AutomationProperties.Name="Validation message" />

            <Border
                Padding="16"
                Stroke="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource Gray600}}"
                StrokeShape="RoundRectangle"
                StrokeThickness="1"
                Background="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray950}}">
                <VerticalStackLayout Spacing="8">
                    <Label
                        Text="{Binding BmiResult}"
                        FontSize="20"
                        FontAttributes="Bold"
                        AutomationProperties.Name="BMI result" />
                    <Label
                        Text="{Binding CalorieResult}"
                        FontSize="18"
                        AutomationProperties.Name="Calorie result" />
                </VerticalStackLayout>
            </Border>

            <Button
                Text="Return to Home"
                Command="{Binding NavigateBackCommand}"
                AutomationProperties.Name="Navigate back"
                CornerRadius="12" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
