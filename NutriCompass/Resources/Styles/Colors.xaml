<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Restaurant-inspired palette -->
    <Color x:Key="Primary">#E53935</Color>
    <Color x:Key="PrimaryDark">#B71C1C</Color>
    <Color x:Key="PrimaryDarkText">#1C1C1E</Color>
    <Color x:Key="Secondary">#2E7D32</Color>
    <Color x:Key="SecondaryDarkText">#1B5E20</Color>
    <Color x:Key="Tertiary">#FFF2E2</Color>
    <Color x:Key="Accent">#FFEB3B</Color>
    <Color x:Key="Contrast">#1B1464</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="MidnightBlue">#1B1464</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Sand">#FFF2E1</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="ContrastBrush" Color="{StaticResource Contrast}"/>
    <SolidColorBrush x:Key="CreamBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="CharcoalBrush" Color="{StaticResource OffBlack}"/>
</ResourceDictionary>
