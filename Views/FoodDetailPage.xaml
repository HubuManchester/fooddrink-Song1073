<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FoodDrinkApp.ViewModels"
             x:Class="FoodDrinkApp.Views.FoodDetailPage"
             Title="Food Details"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--  HERO HEADER – tall gradient with layered icons        -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid MinimumHeightRequest="200" BackgroundColor="{Binding Item.CategoryBadgeColor}">

                <!-- ── Layer 0: Category-colour base (always visible) ── -->
                <BoxView Color="{Binding Item.CategoryBadgeColor}" />

                <!-- ── Layer 1a: Icon fallback (shown when NO photo) ── -->
                <Label x:Name="HeroEmojiBg" Text="{Binding Item.CategoryIcon}" FontFamily="FluentIcons" FontSize="130"
                       HorizontalOptions="End" VerticalOptions="End"
                       Margin="0,0,20,10" Opacity="0.15" TextColor="White">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Item.HasImage}" Value="True">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label x:Name="HeroEmojiMain" Text="{Binding Item.CategoryIcon}" FontFamily="FluentIcons" FontSize="72"
                       HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.95" TextColor="White">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Item.HasImage}" Value="True">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- ── Layer 1b: Full-bleed photo (shown when photo exists) ── -->
                <Image Source="{Binding Item.ResolvedImageSource}" Aspect="AspectFill"
                       HorizontalOptions="Fill" VerticalOptions="Fill">
                    <Image.Triggers>
                        <DataTrigger TargetType="Image" Binding="{Binding Item.HasImage}" Value="False">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Image.Triggers>
                </Image>

                <!-- Layer 2 (Dark scrim) removed to ensure food image is bright and visible -->

                <!-- ── Layer 3: Top row – Back + Category badge ── -->
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="16,16,16,0"
                      VerticalOptions="Start">

                    <!-- Back button pill -->
                    <Border Grid.Column="0" Padding="10,6"
                            StrokeShape="RoundRectangle 20" StrokeThickness="0"
                            BackgroundColor="#55000000">
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                            </HorizontalStackLayout.GestureRecognizers>
                            <Label Text="&#xf15b;" FontFamily="FluentIcons" FontSize="16" TextColor="White"
                                   VerticalOptions="Center" />
                            <Label Text="Back" FontSize="14" TextColor="White"
                                   FontAttributes="Bold" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Category badge pill (top-right) -->
                    <Border Grid.Column="2" Padding="14,6"
                            StrokeShape="RoundRectangle 20" StrokeThickness="0"
                            BackgroundColor="White" Opacity="0.92">
                        <Label Text="{Binding Item.Category}" FontSize="13" FontAttributes="Bold"
                               TextColor="{Binding Item.CategoryBadgeColor}" />
                    </Border>
                </Grid>

                <!-- (Layer 4 removed per request) -->
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--  CONTENT AREA – overlaps hero with rounded top         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Margin="0,-28,0,0" Padding="16,28,16,30"
                    StrokeShape="RoundRectangle 28,28,0,0" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
                <VerticalStackLayout Spacing="16">

                    <!-- ── Food name + location row ── -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding Item.Name}" FontSize="28" FontAttributes="Bold"
                               FontFamily="PlayfairBold" CharacterSpacing="0.3"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />

                        <HorizontalStackLayout Spacing="6">
                            <Label Text="&#xf4f8;" FontFamily="FluentIcons" FontSize="14" VerticalOptions="Center" TextColor="{StaticResource AccentBlue}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Item.LocationText.Length}" Value="0">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Text="{Binding Item.LocationText}" FontSize="14"
                                   TextColor="{StaticResource AccentBlue}" FontAttributes="Bold"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding Item.LocationText.Length}" Value="0">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>

                        <!-- Short calorie summary chip -->
                        <Border Padding="10,5" Margin="0,4,0,0"
                                StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3E2723}"
                                HorizontalOptions="Start">
                            <Label Text="{Binding Item.ShortNutritionLabel}" FontSize="13"
                                   TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}"
                                   FontAttributes="Bold" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  NUTRITION STATS – 2×2 card grid             -->
                    <!-- ═════════════════════════════════════════════ -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nutrition Facts" FontSize="18" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />

                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto"
                              ColumnSpacing="10" RowSpacing="10">

                            <!-- Calories card -->
                            <Border Grid.Row="0" Grid.Column="0" Padding="14"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                                </Border.Shadow>
                                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                    <Border WidthRequest="42" HeightRequest="42"
                                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                            BackgroundColor="#15FF6B35">
                                        <Label Text="&#xf443;" FontFamily="FluentIcons" FontSize="20"
                                               TextColor="{StaticResource AccentOrange}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Calories, StringFormat='{0}'}"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource AccentOrange}" />
                                        <Label Text="Calories" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Protein card -->
                            <Border Grid.Row="0" Grid.Column="1" Padding="14"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                                </Border.Shadow>
                                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                    <Border WidthRequest="42" HeightRequest="42"
                                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                            BackgroundColor="#154CAF50">
                                        <Label Text="&#xf362;" FontFamily="FluentIcons" FontSize="20"
                                               TextColor="{StaticResource AccentGreen}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Protein, StringFormat='{0}g'}"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource AccentGreen}" />
                                        <Label Text="Protein" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Carbs card -->
                            <Border Grid.Row="1" Grid.Column="0" Padding="14"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                                </Border.Shadow>
                                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                    <Border WidthRequest="42" HeightRequest="42"
                                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                            BackgroundColor="#152196F3">
                                        <Label Text="&#xf1ec;" FontFamily="FluentIcons" FontSize="20"
                                               TextColor="{StaticResource AccentBlue}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Carbs, StringFormat='{0}g'}"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource AccentBlue}" />
                                        <Label Text="Carbs" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Fat card -->
                            <Border Grid.Row="1" Grid.Column="1" Padding="14"
                                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                                </Border.Shadow>
                                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                    <Border WidthRequest="42" HeightRequest="42"
                                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                                            BackgroundColor="#15E91E63">
                                        <Label Text="&#xe472;" FontFamily="FluentIcons" FontSize="20"
                                               TextColor="{StaticResource AccentPink}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding Item.Fat, StringFormat='{0}g'}"
                                               FontSize="20" FontAttributes="Bold"
                                               TextColor="{StaticResource AccentPink}" />
                                        <Label Text="Fat" FontSize="11"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  DESCRIPTION CARD – with accent side bar     -->
                    <!-- ═════════════════════════════════════════════ -->
                    <Border Padding="0" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="5, *">
                            <!-- Accent side bar -->
                            <BoxView Grid.Column="0" Color="{Binding Item.CategoryBadgeColor}"
                                     CornerRadius="16,0,16,0" />
                            <VerticalStackLayout Grid.Column="1" Spacing="8" Padding="16">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="&#xe30a;" FontFamily="FluentIcons" FontSize="16" VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                    <Label Text="About This Item" FontSize="16" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding Item.Description}" FontSize="15" LineHeight="1.6"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  ALLERGY ALERT – prominent warning banner     -->
                    <!-- ═════════════════════════════════════════════ -->
                    <Border Padding="16" StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light=#FFCC80, Dark=#5D4037}"
                            StrokeThickness="1.5"
                            BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#3E2723}">
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="14">
                            <!-- Warning icon circle -->
                            <Border Grid.Column="0"
                                    WidthRequest="44" HeightRequest="44"
                                    StrokeShape="RoundRectangle 22" StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFE0B2, Dark=#4E342E}"
                                    HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="&#xf114;" FontFamily="FluentIcons" FontSize="20"
                                       TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="Allergy Information" FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#E65100, Dark=#FFB74D}" />
                                <Label Text="{Binding Item.AllergyNote}" FontSize="14" LineHeight="1.4"
                                       TextColor="{AppThemeBinding Light=#BF360C, Dark=#FFCC80}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  TAGS – horizontal chip-style display         -->
                    <!-- ═════════════════════════════════════════════ -->
                    <Border Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xf77c;" FontFamily="FluentIcons" FontSize="16" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                <Label Text="Tags" FontSize="16" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Border Padding="10,6" StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1.5"
                                    Stroke="{StaticResource AccentPurple}"
                                    BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#1A0033}"
                                    HorizontalOptions="Start">
                                <Label Text="{Binding Item.Tags}" FontSize="14"
                                       TextColor="{StaticResource AccentPurple}" FontAttributes="Bold" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  ADD TO DIET – log this food to today's record -->
                    <!-- ═════════════════════════════════════════════ -->
                    <Border Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xf10c;" FontFamily="FluentIcons" FontSize="16" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                <Label Text="Add to Today's Diet" FontSize="16" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                            </HorizontalStackLayout>
                            <Label Text="Log this food item to your daily diet record."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                            <Button Text="Add to Diet Record" Command="{Binding AddToDietCommand}"
                                    BackgroundColor="{StaticResource AccentGreen}" TextColor="White"
                                    CornerRadius="12" MinimumHeightRequest="48" FontAttributes="Bold"
                                    FontSize="15" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  ACCESSIBILITY ACTIONS – TTS controls         -->
                    <!-- ═════════════════════════════════════════════ -->
                    <Border Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xf103;" FontFamily="FluentIcons" FontSize="16" VerticalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                <Label Text="Accessibility" FontSize="16" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                            </HorizontalStackLayout>
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Read Aloud" Command="{Binding SpeakCommand}"
                                        BackgroundColor="{StaticResource AccentBlue}" TextColor="White"
                                        CornerRadius="12" FontAttributes="Bold" MinimumHeightRequest="48"
                                        FontSize="14" />
                                <Button Grid.Column="1"
                                        Text="Stop" Command="{Binding StopSpeakCommand}"
                                        BackgroundColor="{AppThemeBinding Light=#ECEFF1, Dark=#37474F}"
                                        TextColor="{AppThemeBinding Light=#37474F, Dark=#ECEFF1}"
                                        CornerRadius="12" MinimumHeightRequest="48" FontSize="14" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═════════════════════════════════════════════ -->
                    <!--  DANGER ZONE – delete with clear separation   -->
                    <!-- ═════════════════════════════════════════════ -->
                    <Border Padding="16" StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light=#FFCDD2, Dark=#4E0000}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FFF5F5, Dark=#2C0B0B}"
                            Margin="0,4,0,0">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="&#xf114;" FontFamily="FluentIcons" FontSize="14" VerticalOptions="Center"
                                       TextColor="{StaticResource AccentRed}" />
                                <Label Text="Danger Zone" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource AccentRed}" />
                            </HorizontalStackLayout>
                            <Button Text="Delete This Food" Command="{Binding DeleteCommand}"
                                    BackgroundColor="{StaticResource AccentRed}" TextColor="White"
                                    CornerRadius="12" MinimumHeightRequest="48" FontAttributes="Bold"
                                    FontSize="15" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>