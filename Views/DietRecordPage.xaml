<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FoodDrinkApp.ViewModels"
             x:Class="FoodDrinkApp.Views.DietRecordPage"
             Title="Today's Diet"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Grid>
        <!-- ── Main content layer ── -->
        <Grid RowDefinitions="Auto, *">

            <!-- ═══════════════════════════════════════════════ -->
            <!--  Header                                         -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Row="0" StrokeThickness="0" Padding="20,18,20,14"
                    StrokeShape="RoundRectangle 0,0,24,24"
                    BackgroundColor="{AppThemeBinding Light={StaticResource HeaderLight}, Dark={StaticResource HeaderDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.08" Radius="12" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*" RowDefinitions="Auto, Auto" RowSpacing="4">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" ColumnSpacing="8" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="&#xe2dd;" FontFamily="FluentIcons" FontSize="22"
                               TextColor="{StaticResource AccentGreen}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Today's Diet" 
                               FontSize="26" FontAttributes="Bold" FontFamily="PlayfairBold"
                               CharacterSpacing="0.5" LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                    </Grid>

                    <Label Grid.Row="1" Text="{Binding DateText}" 
                           FontSize="13" Margin="0,0,12,2" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════ -->
            <!--  Scrollable Content                             -->
            <!-- ═══════════════════════════════════════════════ -->
            <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsRefreshing}">
                <ScrollView>
                    <VerticalStackLayout Spacing="12" Padding="16,12,16,30">

                        <!-- ── Calorie Progress Card ── -->
                        <Border Padding="18,16" StrokeShape="RoundRectangle 18" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,3" Opacity="0.08" Radius="10" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <!-- Top row: consumed / target -->
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="Calories Consumed" FontSize="13"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                        <Label Text="{Binding ConsumedText}" FontSize="36" FontAttributes="Bold"
                                               TextColor="{StaticResource AccentOrange}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" HorizontalOptions="End">
                                        <Label Text="Target" FontSize="12" HorizontalTextAlignment="End"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                        <Label Text="{Binding TargetText}" FontSize="17" FontAttributes="Bold" HorizontalTextAlignment="End"
                                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Progress bar -->
                                <Grid HeightRequest="10" Margin="0,2,0,0">
                                    <Border StrokeShape="RoundRectangle 5" StrokeThickness="0" 
                                            BackgroundColor="{AppThemeBinding Light=#EEEEEE, Dark=#252535}" />
                                    <Border WidthRequest="{Binding ProgressBarWidth}" StrokeShape="RoundRectangle 5" StrokeThickness="0"
                                            BackgroundColor="{Binding ProgressColor}" HorizontalOptions="Start" />
                                </Grid>

                                <!-- Remaining + macros -->
                                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8" Margin="0,4,0,0">
                                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="{Binding RemainingText}" FontSize="17" FontAttributes="Bold"
                                               HorizontalOptions="Center" TextColor="{Binding RemainingColor}" />
                                        <Label Text="Remaining" FontSize="10" HorizontalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="{Binding TodayProteinText}" FontSize="17" FontAttributes="Bold"
                                               HorizontalOptions="Center" TextColor="{StaticResource AccentBlue}" />
                                        <Label Text="Protein" FontSize="10" HorizontalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="{Binding TodayCarbsText}" FontSize="17" FontAttributes="Bold"
                                               HorizontalOptions="Center" TextColor="{StaticResource AccentAmber}" />
                                        <Label Text="Carbs" FontSize="10" HorizontalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- ── Meal Sections (built dynamically) ── -->
                        <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding MealSections}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C30}">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                                        </Border.Shadow>
                                        <VerticalStackLayout Spacing="10">
                                            <!-- Meal header -->
                                            <Grid ColumnDefinitions="*, Auto">
                                                <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                                                    <BoxView WidthRequest="4" HeightRequest="20" CornerRadius="2"
                                                             Color="{Binding Color}" VerticalOptions="Center" />
                                                    <Label Text="{Binding Icon}" FontFamily="FluentIcons" FontSize="18" TextColor="{Binding Color}" VerticalOptions="Center" />
                                                    <Label Text="{Binding MealName}" FontSize="17" FontAttributes="Bold" FontFamily="SegoeSemibold" CharacterSpacing="0.3" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                                <Label Grid.Column="1" Text="{Binding CaloriesText}" FontSize="14" FontAttributes="Bold" TextColor="{Binding Color}" VerticalOptions="Center" />
                                            </Grid>
                                            <!-- Divider -->
                                            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E5E7EB, Dark=#2A2A42}" />
                                            
                                            <!-- Items -->
                                            <VerticalStackLayout Spacing="0" BindableLayout.ItemsSource="{Binding Items}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnDefinitions="36, *, Auto, 32" ColumnSpacing="10" Padding="0,4">
                                                            <Label Grid.Column="0" Text="{Binding FoodIcon}" FontFamily="FluentIcons" FontSize="22" 
                                                                   TextColor="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MealGroup}}, Path=Color}" 
                                                                   VerticalOptions="Center" HorizontalOptions="Center" />
                                                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                                <Label Text="{Binding FoodName}" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                                                <Label Text="{Binding ServingsLabel}" FontSize="11" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                                            </VerticalStackLayout>
                                                            <Label Grid.Column="2" Text="{Binding CaloriesLabel}" FontSize="13" FontAttributes="Bold" 
                                                                   TextColor="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MealGroup}}, Path=Color}" 
                                                                   VerticalOptions="Center" HorizontalTextAlignment="End" />
                                                            <Label Grid.Column="3" Text="&#xf114;" FontFamily="FluentIcons" FontSize="16" TextColor="#F44336" 
                                                                   VerticalOptions="Center" HorizontalOptions="Center">
                                                                <Label.GestureRecognizers>
                                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:DietRecordViewModel}}, Path=DeleteRecordCommand}" CommandParameter="{Binding .}" />
                                                                </Label.GestureRecognizers>
                                                            </Label>
                                                        </Grid>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- ── Empty State ── -->
                        <Border Padding="30" StrokeShape="RoundRectangle 16" StrokeThickness="0" IsVisible="{Binding IsEmpty}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="&#xf1ec;" FontFamily="FluentIcons" FontSize="48" HorizontalOptions="Center"
                                       TextColor="{StaticResource AccentPurple}" />
                                <Label Text="No meals recorded today" FontSize="17" FontAttributes="Bold" HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                <Label Text="Tap the + button to add food to your daily record."
                                       FontSize="13" HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Floating Action Button (FAB)                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border WidthRequest="56" HeightRequest="56"
                StrokeShape="RoundRectangle 28" StrokeThickness="0"
                BackgroundColor="{StaticResource AccentGreen}"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,20,20">
            <Border.Shadow>
                <Shadow Brush="{StaticResource AccentGreen}" Offset="0,4" Opacity="0.35" Radius="12" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AddFoodCommand}" />
            </Border.GestureRecognizers>
            <Label Text="&#xf109;" FontFamily="FluentIcons" TextColor="White" FontSize="24"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
