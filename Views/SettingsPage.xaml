<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.SettingsPage"
             Title="Settings"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Grid RowDefinitions="Auto, *">

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Premium Header                                 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" StrokeThickness="0" Padding="20,18,20,14"
                StrokeShape="RoundRectangle 0,0,24,24"
                BackgroundColor="{AppThemeBinding Light={StaticResource HeaderLight}, Dark={StaticResource HeaderDark}}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Opacity="0.08" Radius="12" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="4">
                <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="&#xf6a9;" FontFamily="FluentIcons" FontSize="24"
                           TextColor="{StaticResource AccentPurple}" VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Settings" 
                           FontSize="26" FontAttributes="Bold" FontFamily="PlayfairBold"
                           CharacterSpacing="0.5" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                </Grid>
                <Label Text="Customise your experience and accessibility" 
                       FontSize="13" Margin="0,0,12,2" LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
            </VerticalStackLayout>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Scrollable Content                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16,12,16,30">

                <!-- ── Accessibility Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xf103;" FontFamily="FluentIcons" FontSize="18"
                                   TextColor="{StaticResource AccentBlue}" VerticalOptions="Center" />
                            <Label Text="Accessibility" FontSize="17" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <Label Text="Adjust settings for better readability."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />

                        <!-- Dark Mode Toggle -->
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" MinimumHeightRequest="48">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="&#xf87d;" FontFamily="FluentIcons" FontSize="16"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" VerticalOptions="Center" />
                                    <Label Text="Dark Mode" FontSize="15" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                </HorizontalStackLayout>
                                <Label Text="Switch to a dark colour scheme." FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                            </VerticalStackLayout>
                            <Switch x:Name="ThemeSwitch" Grid.Column="1" Toggled="OnThemeToggled"
                                    OnColor="{StaticResource AccentPurple}" />
                        </Grid>
                        
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />
                        
                        <!-- Large Text Toggle -->
                        <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center" MinimumHeightRequest="48">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="&#xf7e6;" FontFamily="FluentIcons" FontSize="16"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" VerticalOptions="Center" />
                                    <Label Text="Large Text" FontSize="15" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                </HorizontalStackLayout>
                                <Label Text="Increase font size across the app." FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                            </VerticalStackLayout>
                            <Switch x:Name="LargeTextSwitch" Grid.Column="1" Toggled="OnLargeTextToggled"
                                    OnColor="{StaticResource AccentPurple}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ── About Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xf4a3;" FontFamily="FluentIcons" FontSize="18"
                                   TextColor="{StaticResource AccentPurple}" VerticalOptions="Center" />
                            <Label Text="About" FontSize="17" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource DividerLight}, Dark={StaticResource DividerDark}}" />
                        <Label Text="Tasty Meal Planner" FontAttributes="Bold" FontSize="20"
                               FontFamily="PlayfairBold" CharacterSpacing="0.5"
                               TextColor="{StaticResource AccentPurple}" />
                        <Label Text="Version 1.0.0" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                        <Label Text="Developed as a Mobile Application module project." FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                        <Label Text="A premium food tracking experience with nutrition analytics, hardware integration, and accessibility support."
                               FontSize="12" LineHeight="1.4"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>