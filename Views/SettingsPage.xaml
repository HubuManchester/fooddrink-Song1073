<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.SettingsPage"
             Title="Settings &amp; Accessibility"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20,16,20,30">

            <!-- Header -->
            <Label Text="⚙️ Settings" FontSize="26" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
            <Label Text="Customise your experience and accessibility preferences."
                   FontSize="14" Margin="0,0,0,5"
                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />

            <!-- ── Accessibility Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">
                    <Label Text="♿ Accessibility" FontSize="18" FontAttributes="Bold" />
                    <Label Text="Ensure the app is accessible to all users (WCAG Guidelines)."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />

                    <!-- Dark Mode Toggle -->
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="🌙 Dark Mode" FontSize="16" FontAttributes="Bold" />
                            <Label Text="Switch to a dark colour scheme." FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                        </VerticalStackLayout>
                        <Switch x:Name="ThemeSwitch" Grid.Column="1" Toggled="OnThemeToggled"
                                OnColor="{StaticResource AccentPurple}" />
                    </Grid>
                    
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" />
                    
                    <!-- Large Text Toggle -->
                    <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                            <Label Text="🔎 Large Text Mode" FontSize="16" FontAttributes="Bold" />
                            <Label Text="Increase font size across the app." FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                        </VerticalStackLayout>
                        <Switch x:Name="LargeTextSwitch" Grid.Column="1" Toggled="OnLargeTextToggled"
                                OnColor="{StaticResource AccentPurple}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── About Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="ℹ️ About App" FontSize="18" FontAttributes="Bold" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" />
                    <Label Text="Tasty Meal Planner" FontAttributes="Bold" FontSize="16"
                           TextColor="{StaticResource AccentPurple}" />
                    <Label Text="Version 1.0.0" FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                    <Label Text="Developed for 6G6Z0014 Assessment." FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                    <Label Text="A premium food and drink tracking experience with nutrition analytics, hardware integration, and full accessibility support."
                           FontSize="13" LineHeight="1.4"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>