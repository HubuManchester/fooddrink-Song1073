<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.AddItemPage"
             Title="Add New Record"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20,16,20,30">

            <!-- Header -->
            <Label Text="🍴 New Food/Drink" FontSize="26" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
            <Label Text="Fill in the details below to add a new item to your collection."
                   FontSize="14" Margin="0,0,0,5"
                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />

            <!-- ── Media & Location Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="📸 Media &amp; Location" FontSize="16" FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Button Text="📷 Take Photo" Clicked="OnTakePhotoClicked"
                                BackgroundColor="{StaticResource AccentPurple}" TextColor="White"
                                CornerRadius="10" FontAttributes="Bold" VerticalOptions="Center" />
                        <Border x:Name="ThumbnailBorder" StrokeShape="RoundRectangle 10"
                                StrokeThickness="0" HeightRequest="50" WidthRequest="50"
                                IsVisible="False" VerticalOptions="Center"
                                BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#2A2A35}">
                            <Image x:Name="FoodImageView" Aspect="AspectFill" />
                        </Border>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EEEEEE, Dark=#333333}" />
                    <Button Text="📍 Tag Current Location" Clicked="OnGetLocationClicked"
                            BackgroundColor="{StaticResource AccentTeal}" TextColor="White"
                            CornerRadius="10" FontAttributes="Bold" />
                    <Label x:Name="LocationLabel" Text="No location tagged." FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}"
                           FontAttributes="Italic" />
                </VerticalStackLayout>
            </Border>

            <!-- ── Basic Info Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="📋 Basic Info" FontSize="16" FontAttributes="Bold" />
                    <Entry x:Name="NameEntry" Placeholder="Name (Required)" />
                    <Picker x:Name="CategoryPicker" Title="Select Category (Required)">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Breakfast</x:String>
                                <x:String>Lunch</x:String>
                                <x:String>Dinner</x:String>
                                <x:String>Drink</x:String>
                                <x:String>Snack</x:String>
                                <x:String>Dessert</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                    <Editor x:Name="DescriptionEditor" Placeholder="Description" HeightRequest="80" />
                </VerticalStackLayout>
            </Border>

            <!-- ── Nutrition Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="🔥 Nutrition" FontSize="16" FontAttributes="Bold" />
                    <Entry x:Name="CaloriesEntry" Placeholder="Calories (kcal) - Must be positive number" Keyboard="Numeric" />
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <Entry Grid.Column="0" x:Name="ProteinEntry" Placeholder="Protein (g)" Keyboard="Numeric" />
                        <Entry Grid.Column="1" x:Name="CarbsEntry" Placeholder="Carbs (g)" Keyboard="Numeric" />
                        <Entry Grid.Column="2" x:Name="FatEntry" Placeholder="Fat (g)" Keyboard="Numeric" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ── Extra Info Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label Text="🏷️ Extra Details" FontSize="16" FontAttributes="Bold" />
                    <Entry x:Name="AllergyEntry" Placeholder="Allergy Note (e.g. Dairy, Nuts)" />
                    <Entry x:Name="TagsEntry" Placeholder="Tags (e.g. Healthy, Spicy)" />
                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="✅ Save Record" BackgroundColor="{StaticResource AccentGreen}" TextColor="White"
                    Clicked="OnSaveClicked" Margin="0,10,0,0" CornerRadius="14"
                    FontSize="18" FontAttributes="Bold" HeightRequest="54" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>