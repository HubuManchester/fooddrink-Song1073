<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FoodDrinkApp.ViewModels"
             x:Class="FoodDrinkApp.Views.ProfilePage"
             Title="Profile"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Grid>
        <!-- ── Main content layer ── -->
        <Grid RowDefinitions="Auto, *">

            <!-- ═══════════════════════════════════════════════ -->
            <!--  Header                                         -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Row="0" StrokeThickness="0" Padding="20,18,20,14"
                    StrokeShape="RoundRectangle 0,0,24,24"
                    BackgroundColor="{AppThemeBinding Light={StaticResource HeaderLight}, Dark={StaticResource HeaderDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.08" Radius="12" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*" RowDefinitions="Auto, Auto" RowSpacing="4">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" ColumnSpacing="8" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="&#xf5bd;" FontFamily="FluentIcons" FontSize="22"
                               TextColor="{StaticResource AccentPurple}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="My Profile" 
                               FontSize="26" FontAttributes="Bold" FontFamily="PlayfairBold"
                               CharacterSpacing="0.5" LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                    </Grid>
                    <Label Grid.Row="1" Text="Track your daily calorie needs" 
                           FontSize="13" Margin="0,0,12,2" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════ -->
            <!--  Scrollable Content                             -->
            <!-- ═══════════════════════════════════════════════ -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Spacing="12" Padding="16,12,16,30">

                    <!-- ── Active Profile Calorie Dashboard ── -->
                    <Border IsVisible="{Binding HasActiveProfile}" Padding="18,16" StrokeShape="RoundRectangle 18" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,3" Opacity="0.08" Radius="10" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="&#xf443;" FontFamily="FluentIcons" FontSize="18"
                                       TextColor="{StaticResource AccentOrange}" VerticalOptions="Center" />
                                <Label Text="Today's Calorie Budget" FontSize="18" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding ActiveProfileLabel}" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                            
                            <!-- Big calorie number -->
                            <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding CalorieTargetText}" FontSize="40" FontAttributes="Bold"
                                           TextColor="{StaticResource AccentOrange}" />
                                    <Label Text="kcal / day" FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding GoalIcon}" FontFamily="FluentIcons" FontSize="34"
                                           TextColor="{StaticResource AccentPurple}" HorizontalOptions="Center" />
                                    <Label Text="{Binding GoalLabel}" FontSize="12" FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           TextColor="{StaticResource AccentPurple}" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Macro breakdown -->
                            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0" Padding="14"
                                    BackgroundColor="{AppThemeBinding Light=#F5F0FF, Dark=#221D35}">
                                <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="&#xf362;" FontFamily="FluentIcons" FontSize="18" HorizontalOptions="Center"
                                               TextColor="{StaticResource AccentBlue}" />
                                        <Label Text="{Binding ProteinText}" FontSize="16" FontAttributes="Bold"
                                               HorizontalOptions="Center" TextColor="{StaticResource AccentBlue}" />
                                        <Label Text="Protein" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="&#xf1ec;" FontFamily="FluentIcons" FontSize="18" HorizontalOptions="Center"
                                               TextColor="{StaticResource AccentAmber}" />
                                        <Label Text="{Binding CarbsText}" FontSize="16" FontAttributes="Bold"
                                               HorizontalOptions="Center" TextColor="{StaticResource AccentAmber}" />
                                        <Label Text="Carbs" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                        <Label Text="&#xe472;" FontFamily="FluentIcons" FontSize="18" HorizontalOptions="Center"
                                               TextColor="{StaticResource AccentPink}" />
                                        <Label Text="{Binding FatText}" FontSize="16" FontAttributes="Bold"
                                               HorizontalOptions="Center" TextColor="{StaticResource AccentPink}" />
                                        <Label Text="Fat" FontSize="11" HorizontalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <!-- Location + last refresh -->
                            <Grid ColumnDefinitions="*, Auto" Margin="0,2,0,0">
                                <Label Grid.Column="0" Text="{Binding LocationText}" FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}"
                                       VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding RefreshDateText}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Profile List ── -->
                    <HorizontalStackLayout Spacing="8" Margin="2,4,0,0">
                        <Label Text="&#xf5bd;" FontFamily="FluentIcons" FontSize="16"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" VerticalOptions="Center" />
                        <Label Text="Saved Profiles" FontSize="17" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                    </HorizontalStackLayout>
                    
                    <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Profiles}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:ProfileCardViewModel">
                                <Border StrokeShape="RoundRectangle 16" Stroke="{Binding CardStroke}" StrokeThickness="{Binding CardStrokeThickness}" Padding="16"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1C1C30}">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Opacity="0.08" Radius="6" />
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="50, *, Auto" ColumnSpacing="14">
                                        <!-- Avatar -->
                                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 24" StrokeThickness="0" BackgroundColor="#267C4DFF" VerticalOptions="Center">
                                            <Grid>
                                                <Image Source="{Binding ImageSource}" Aspect="AspectFill" WidthRequest="48" HeightRequest="48" IsVisible="{Binding HasImage}" />
                                                <Label Text="&#xf5bd;" FontFamily="FluentIcons" FontSize="24" TextColor="{Binding AccentColor}" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasNoImage}" />
                                            </Grid>
                                        </Border>

                                        <!-- Text info -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" FontFamily="SegoeSemibold" TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding DetailsText}" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#9CA3AF}" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding GoalIcon}" FontFamily="FluentIcons" FontSize="14" TextColor="{Binding AccentColor}" VerticalOptions="Center" />
                                                <Label Text="{Binding GoalText}" FontSize="12" TextColor="{Binding AccentColor}" FontAttributes="Bold" />
                                            </HorizontalStackLayout>
                                            <!-- Active Badge -->
                                            <Border IsVisible="{Binding IsActive}" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#4CAF50" Padding="8,2" HorizontalOptions="Start" Margin="0,3,0,0">
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="&#xe3b3;" FontFamily="FluentIcons" FontSize="10" TextColor="White" VerticalOptions="Center" />
                                                    <Label Text="Active" FontSize="10" FontAttributes="Bold" TextColor="White" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </VerticalStackLayout>

                                        <!-- Action buttons -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                                            <!-- Switch Button -->
                                            <Border IsVisible="{Binding IsNotActive}" StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#7C4DFF" Padding="10,6" HorizontalOptions="End">
                                                <Label Text="Switch" FontSize="11" TextColor="White" FontAttributes="Bold" />
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProfileViewModel}}, Path=SwitchProfileCommand}" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                            <!-- Delete Button -->
                                            <Border StrokeShape="RoundRectangle 10" StrokeThickness="0" BackgroundColor="#1EF44336" Padding="10,6" HorizontalOptions="End">
                                                <Label Text="&#xf114;" FontFamily="FluentIcons" FontSize="16" TextColor="#F44336" HorizontalOptions="Center" />
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ProfileViewModel}}, Path=DeleteProfileCommand}" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                            </Border>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- ── Empty state ── -->
                    <Border IsVisible="{Binding IsEmpty}" Padding="30" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                        <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="&#xf5bd;" FontFamily="FluentIcons" FontSize="48" HorizontalOptions="Center"
                                   TextColor="{StaticResource AccentPurple}" />
                            <Label Text="No profiles yet" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                            <Label Text="Tap the + button to create your first profile and start tracking."
                                   FontSize="13" HorizontalOptions="Center" HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Floating Action Button (FAB)                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border WidthRequest="56" HeightRequest="56"
                StrokeShape="RoundRectangle 28" StrokeThickness="0"
                BackgroundColor="{StaticResource AccentPurple}"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,20,20">
            <Border.Shadow>
                <Shadow Brush="{StaticResource AccentPurple}" Offset="0,4" Opacity="0.35" Radius="12" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AddProfileCommand}" />
            </Border.GestureRecognizers>
            <Label Text="&#xf109;" FontFamily="FluentIcons" TextColor="White" FontSize="24"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>
