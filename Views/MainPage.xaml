<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.MainPage"
             Title="Tasty Meal Planner"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Grid>
        <!-- ── Main content layer ── -->
        <Grid RowDefinitions="Auto, *">

            <!-- ═══════════════════════════════════════════════ -->
            <!--  Premium Header                                -->
            <!-- ═══════════════════════════════════════════════ -->
            <Border Grid.Row="0" StrokeThickness="0" Padding="20,18,20,12"
                    StrokeShape="RoundRectangle 0,0,24,24"
                    BackgroundColor="{AppThemeBinding Light={StaticResource HeaderLight}, Dark={StaticResource HeaderDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Opacity="0.08" Radius="12" />
                </Border.Shadow>
                <Grid ColumnDefinitions="*" RowDefinitions="Auto, Auto, Auto" RowSpacing="4">
                    <!-- App Title with icon -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto, *" ColumnSpacing="8" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="&#xf1ec;" FontFamily="FluentIcons" FontSize="24"
                               TextColor="{StaticResource AccentPurple}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Tasty Meal Planner" 
                               FontSize="26" FontAttributes="Bold" FontFamily="PlayfairBold"
                               CharacterSpacing="0.5" LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                    </Grid>
                    
                    <!-- Subtitle -->
                    <Label Grid.Row="1" Text="Discover and track your meals" 
                           FontSize="13" Margin="0,0,12,8" LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                    
                    <!-- Search Bar -->
                    <Border Grid.Row="2" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource InputBgLight}, Dark={StaticResource InputBgDark}}"
                            Padding="0">
                        <SearchBar x:Name="FoodSearchBar" 
                                   Placeholder="Search foods, categories, or tags..." 
                                   SearchButtonPressed="OnSearchPressed"
                                   BackgroundColor="Transparent" />
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════ -->
            <!--  Main scrollable content area                  -->
            <!-- ═══════════════════════════════════════════════ -->
            <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
                <ScrollView>
                    <VerticalStackLayout x:Name="ContentArea" Spacing="0" Padding="0,10,0,24">
                        
                        <!-- ── Today's Summary Card ── -->
                        <Border Margin="16,6,16,10" Padding="18,16" StrokeShape="RoundRectangle 16" StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="8" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="5">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="&#xe2dd;" FontFamily="FluentIcons" FontSize="18"
                                           TextColor="{StaticResource AccentPurple}" VerticalOptions="Center" />
                                    <Label Text="Today's Summary" FontSize="17" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                                </HorizontalStackLayout>
                                <Label x:Name="TotalCountLabel" Text="Loading..." FontSize="13"
                                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                                <Label x:Name="TotalCaloriesLabel" Text="" FontSize="13"
                                       TextColor="{StaticResource AccentOrange}" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- ── Dynamic category sections are populated in code-behind ── -->
                        <VerticalStackLayout x:Name="CategoriesContainer" Spacing="2" />
                        
                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Floating Action Button (FAB)                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border WidthRequest="56" HeightRequest="56"
                StrokeShape="RoundRectangle 28" StrokeThickness="0"
                BackgroundColor="{StaticResource AccentPurple}"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,20,20">
            <Border.Shadow>
                <Shadow Brush="{StaticResource AccentPurple}" Offset="0,4" Opacity="0.35" Radius="12" />
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddClicked" />
            </Border.GestureRecognizers>
            <Label Text="&#xf109;" FontFamily="FluentIcons" TextColor="White" FontSize="24"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Border>
    </Grid>
</ContentPage>