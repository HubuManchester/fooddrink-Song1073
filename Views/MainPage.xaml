<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.MainPage"
             Title="Food &amp; Drink Assistant">

    <Grid RowDefinitions="Auto, *, Auto">
        <SearchBar Grid.Row="0" x:Name="FoodSearchBar" Placeholder="Search foods, categories, or tags..." SearchButtonPressed="OnSearchPressed" />

        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection" SelectionMode="Single" SelectionChanged="OnFoodSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10,5" Padding="15" StrokeShape="RoundRectangle 10" 
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.2" Radius="4" />
                            </Border.Shadow>
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding Category}" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding CaloriesLabel}" FontSize="14" TextColor="Tomato" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button Grid.Row="2" Text="Add New Record" Margin="15" BackgroundColor="Tomato" TextColor="White" Clicked="OnAddClicked" />
    </Grid>
</ContentPage>