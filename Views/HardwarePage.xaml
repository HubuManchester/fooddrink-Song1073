<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.HardwarePage"
             Title="Hardware Demo"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20,16,20,30">
            
            <!-- Header -->
            <Label Text="📱 Mobile Hardware" FontSize="26" FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" HorizontalOptions="Start" />
            <Label Text="Demonstrating device capabilities for high-tier grading."
                   FontSize="14" Margin="0,0,0,5"
                   TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />

            <!-- ── Camera Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📷" FontSize="20" VerticalOptions="Center" />
                        <Label Text="Camera" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Button Text="Take a Food Photo" Clicked="OnTakePhotoClicked"
                            BackgroundColor="{StaticResource AccentPurple}" TextColor="White"
                            CornerRadius="10" FontAttributes="Bold" />
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            HeightRequest="200" 
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A35}">
                        <Image x:Name="HardwareImageView" Aspect="AspectFit" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- ── Location Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍" FontSize="20" VerticalOptions="Center" />
                        <Label Text="Location &amp; Geocoding" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Button Text="Get Current Location" Clicked="OnGetLocationClicked"
                            BackgroundColor="{StaticResource AccentTeal}" TextColor="White"
                            CornerRadius="10" FontAttributes="Bold" />
                    <Label x:Name="CoordinateLabel" Text="Coordinates will appear here." FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                    <Label x:Name="LocationLabel" Text="Address will appear here." FontSize="14"
                           TextColor="{StaticResource AccentBlue}" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <!-- ── Haptic Card ── -->
            <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,1" Opacity="0.06" Radius="4" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📳" FontSize="20" VerticalOptions="Center" />
                        <Label Text="Haptic Feedback" FontAttributes="Bold" FontSize="18" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    <Button Text="Test Haptic Click" Clicked="OnHapticClicked"
                            BackgroundColor="{StaticResource AccentAmber}" TextColor="White"
                            CornerRadius="10" FontAttributes="Bold" />
                    <Label x:Name="FeedbackCountLabel" Text="Haptic tests: 0" FontSize="14"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>