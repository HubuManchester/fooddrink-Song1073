<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.Views.EditProfilePage"
             Title="New Profile"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}">

    <Grid RowDefinitions="Auto, *">

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Premium Header                                 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" StrokeThickness="0" Padding="20,18,20,14"
                StrokeShape="RoundRectangle 0,0,24,24"
                BackgroundColor="{AppThemeBinding Light={StaticResource HeaderLight}, Dark={StaticResource HeaderDark}}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Opacity="0.08" Radius="12" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">
                <!-- Back button -->
                <Border Grid.Row="0" Grid.Column="0" Padding="8,4" Margin="0,0,8,0"
                        StrokeShape="RoundRectangle 12" StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource InputBgLight}, Dark={StaticResource InputBgDark}}"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="&#xf15b;" FontFamily="FluentIcons" FontSize="18"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" VerticalOptions="Center" />
                </Border>
                <!-- Title -->
                <Label Grid.Row="0" Grid.Column="1" Text="Create Profile" 
                       FontSize="24" FontAttributes="Bold" FontFamily="PlayfairBold"
                       CharacterSpacing="0.5" HorizontalOptions="Start" VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Text="Fill in your details to calculate daily calorie needs" 
                       FontSize="13" Margin="0,0,12,2" LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!--  Scrollable Content                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="16,12,16,30">

                <!-- ── Profile Photo Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xf254;" FontFamily="FluentIcons" FontSize="16"
                                   TextColor="{StaticResource AccentPurple}" VerticalOptions="Center" />
                            <Label Text="Profile Photo (Optional)" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <Label Text="Take a photo or pick from gallery. Leave empty for the default icon."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />

                        <!-- Avatar preview (circular) -->
                        <Border WidthRequest="100" HeightRequest="100"
                                StrokeShape="RoundRectangle 50" StrokeThickness="2.5"
                                Stroke="{StaticResource AccentPurple}"
                                BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#1A0033}"
                                HorizontalOptions="Center">
                            <!-- Default icon (shown when no image) -->
                            <Grid>
                                <Label x:Name="DefaultAvatarIcon"
                                       Text="&#xf5bd;" FontFamily="FluentIcons" FontSize="44"
                                       TextColor="{StaticResource AccentPurple}"
                                       HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasNoImage}" />
                                <Image x:Name="ProfileImagePreview" Aspect="AspectFill"
                                       IsVisible="{Binding HasImage}" Source="{Binding ImageSource}"
                                       WidthRequest="100" HeightRequest="100" />
                            </Grid>
                        </Border>

                        <!-- Photo action buttons -->
                        <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                            <Button Grid.Column="0" Text="Take Photo"
                                    FontSize="12"
                                    Command="{Binding TakeProfilePhotoCommand}"
                                    BackgroundColor="{StaticResource AccentPurple}" TextColor="White"
                                    CornerRadius="10" MinimumHeightRequest="38" Padding="6,0" />
                            <Button Grid.Column="1" Text="Gallery"
                                    FontSize="12"
                                    Command="{Binding PickProfilePhotoCommand}"
                                    BackgroundColor="{StaticResource AccentBlue}" TextColor="White"
                                    CornerRadius="10" MinimumHeightRequest="38" Padding="6,0" />
                            <Button Grid.Column="2" x:Name="RemovePhotoBtn"
                                    Text="Remove"
                                    FontSize="12"
                                    Command="{Binding RemoveProfilePhotoCommand}"
                                    BackgroundColor="#F44336" TextColor="White"
                                    CornerRadius="10" MinimumHeightRequest="38" Padding="6,0" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ── Basic Info Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xf4a3;" FontFamily="FluentIcons" FontSize="16"
                                   TextColor="{StaticResource AccentBlue}" VerticalOptions="Center" />
                            <Label Text="Basic Info" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <Entry x:Name="NameEntry" Placeholder="Your Name (Required)" Text="{Binding Name}" />
                        <Picker x:Name="GenderPicker" Title="Select Gender (Required)" ItemsSource="{Binding Genders}" SelectedItem="{Binding Gender}" />
                        <Entry x:Name="AgeEntry" Placeholder="Age (years)" Keyboard="Numeric" Text="{Binding Age}" />
                    </VerticalStackLayout>
                </Border>

                <!-- ── Body Measurements Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xf362;" FontFamily="FluentIcons" FontSize="16"
                                   TextColor="{StaticResource AccentGreen}" VerticalOptions="Center" />
                            <Label Text="Body Measurements" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                            <Entry Grid.Column="0" x:Name="HeightEntry" Placeholder="Height (cm)" Keyboard="Numeric" Text="{Binding Height}" />
                            <Entry Grid.Column="1" x:Name="WeightEntry" Placeholder="Weight (kg)" Keyboard="Numeric" Text="{Binding Weight}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ── Activity & Goal Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xe11c;" FontFamily="FluentIcons" FontSize="16"
                                   TextColor="{StaticResource AccentOrange}" VerticalOptions="Center" />
                            <Label Text="Activity &amp; Goal" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <Picker x:Name="ActivityPicker" Title="Activity Level (Required)" ItemsSource="{Binding ActivityLevels}" SelectedItem="{Binding ActivityLevel}" />
                        <Picker x:Name="GoalPicker" Title="Goal (Required)" ItemsSource="{Binding Goals}" SelectedItem="{Binding Goal}" />
                    </VerticalStackLayout>
                </Border>

                <!-- ── Location Card ── -->
                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Opacity="0.06" Radius="6" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="&#xf4f8;" FontFamily="FluentIcons" FontSize="16"
                                   TextColor="{StaticResource AccentTeal}" VerticalOptions="Center" />
                            <Label Text="Location (Optional)" FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A1A1A, Dark=White}" />
                        </HorizontalStackLayout>
                        <Label Text="Used for climate-based calorie adjustment."
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}" />
                        <Button Text="Get Location" Command="{Binding GetLocationCommand}"
                                BackgroundColor="{StaticResource AccentTeal}" TextColor="White"
                                CornerRadius="12" FontAttributes="Bold" MinimumHeightRequest="44" FontSize="14" />
                        <Label x:Name="LocationLabel" Text="{Binding LocationText}" FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource SubtextLight}, Dark={StaticResource SubtextDark}}"
                               FontAttributes="Italic" />
                    </VerticalStackLayout>
                </Border>

                <!-- Save Button -->
                <Button Text="Save Profile" BackgroundColor="{StaticResource AccentGreen}" TextColor="White"
                        Command="{Binding SaveCommand}" Margin="0,6,0,0" CornerRadius="14"
                        FontSize="17" FontAttributes="Bold" MinimumHeightRequest="52" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
